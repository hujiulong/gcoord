{
  "compilerOptions": {
    "target": "ES2016",
    "sourceMap": false,
    "newLine": "LF",
    "outDir": "./.tmp/ts",
    "rootDir": "./src",
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext"]
  },
  "include": ["src"]
}
