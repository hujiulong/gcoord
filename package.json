{
  "name": "gcoord",
  "version": "1.0.7",
  "description": "geographic coordinate library",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/gcoord.global.prod.js",
  "jsdelivr": "./dist/gcoord.global.prod.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./global": "./dist/gcoord.global.prod.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "node scripts/release.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"README*.md\" \"*.json\" \"*.ts\" \".github/workflows/*.yml\"",
    "gpr-setup": "node scripts/gpr-setup.js"
  },
  "gitHooks": {
    "pre-commit": "lint-staged",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hujiulong/gcoord.git"
  },
  "author": "Jiulong Hu <me@hujiulong.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hujiulong/gcoord/issues"
  },
  "homepage": "https://github.com/hujiulong/gcoord#readme",
  "keywords": [
    "map",
    "coordinate",
    "wgs84",
    "gcj02",
    "bd09"
  ],
  "engines": {
    "node": ">=16.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "chalk": "^5.6.2",
    "conventional-changelog-cli": "^5.0.0",
    "enquirer": "^2.4.1",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "lint-staged": "^17.0.8",
    "minimist": "^1.2.8",
    "prettier": "^3.8.4",
    "semver": "^7.8.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "yorkie": "^2.0.0"
  }
}
